generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ENUMLAR
enum Role {
  ADMIN
  COORDINATOR
  FINANCE
  HR
  SALES
  PURCHASING
  WAREHOUSE_MANAGER
  WAREHOUSE_RECEIVING
  WAREHOUSE_STAFF
}

enum CompanyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum OrderType {
  PURCHASE
  SALE
}

enum OrderStatus {
  PENDING
  COMPLETED
}

enum MovementType {
  WASTE
  RETURN
  ADJUSTMENT
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AccountType {
  CASH
  BANK
}

enum TransactionType {
  COLLECTION
  PAYMENT
  EXPENSE
  INCOME
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum PaymentType {
  SALARY
  ADVANCE
  BONUS
}

enum LeadStatus {
  NEW
  CONTACTED
  MEETING
  PROPOSAL
  WON
  LOST
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  OUT_OF_SERVICE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum MarketplaceName {
  TRENDYOL
  HEPSIBURADA
  AMAZON
  SHOPIFY
}

enum InvoiceDirection {
  INCOMING
  OUTGOING
}

enum InvoiceScenario {
  COMMERCIAL
  BASIC
  EARSIV
}

// 2. MODELLER
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  phone     String
  role      Role     @default(SALES)
  createdAt DateTime @default(now())
}

model Company {
  id           String                 @id @default(cuid())
  name         String
  type         CompanyType
  balance      Float                  @default(0)
  orders       Order[]
  transactions FinancialTransaction[]
}

model Product {
  id                  String          @id @default(cuid())
  name                String
  sku                 String          @unique
  stock               Int             @default(0)
  orderItems          OrderItem[]
  movements           StockMovement[]
  recipeAsMainProduct Recipe?         @relation("MainProduct")
  usedInRecipes       RecipeItem[]    @relation("IngredientProduct")
}

model Order {
  id          String      @id @default(cuid())
  type        OrderType
  status      OrderStatus @default(PENDING)
  totalAmount Float       @default(0)
  createdAt   DateTime    @default(now()) // <-- Bu satırı ekle
  
  companyId   String?
  company     Company?    @relation(fields: [companyId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
}

model StockMovement {
  id          String       @id @default(cuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  type        MovementType
  quantity    Int
  description String?
  createdAt   DateTime     @default(now()) // <-- Bu satırı ekle
}

model Recipe {
  id              String       @id @default(uuid())
  targetProductId String       @unique
  product         Product      @relation("MainProduct", fields: [targetProductId], references: [id])
  targetQuantity  Float
  recipeItems     RecipeItem[]
}

model RecipeItem {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation("IngredientProduct", fields: [productId], references: [id])
  quantity  Float
}

model CashAccount {
  id           String                 @id @default(cuid())
  name         String
  type         AccountType
  balance      Float                  @default(0)
  transactions FinancialTransaction[]
}

model FinancialTransaction {
  id        String          @id @default(cuid())
  accountId String
  account   CashAccount     @relation(fields: [accountId], references: [id])
  companyId String?
  company   Company?        @relation(fields: [companyId], references: [id])
  type      TransactionType
  amount    Float
  createdAt DateTime        @default(now()) // <-- BU SATIR EKSİK, EKLENMELİ
}

model SecurityLog {
  id        String   @id @default(cuid())
  action    String
  module    String
  details   String
  createdAt DateTime @default(now())
}
